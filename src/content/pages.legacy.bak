export function getPage(slug: string) {
  return pages.find((page) => page.slug === slug);
}

export function getRelatedPages(page: SeoPage) {
  return page.related
    .map((slug) => getPage(slug))
    .filter((relatedPage): relatedPage is SeoPage => Boolean(relatedPage));
}
